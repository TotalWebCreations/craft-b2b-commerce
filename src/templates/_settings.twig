{% import '_includes/forms' as forms %}

{% if belowPro %}
    <div class="readable">
        <blockquote class="note warning">
            {{ 'B2B Commerce requires Craft CMS Pro, because business accounts rely on multiple users. The current edition only supports a single user and cannot run the B2B flows.'|t('b2b-commerce') }}
        </blockquote>
    </div>
{% endif %}

{{ forms.lightswitchField({
    label: 'Companies'|t('b2b-commerce'),
    instructions: 'Company accounts are always active in this release; this toggle takes effect in an upcoming release.'|t('b2b-commerce'),
    name: 'enableCompanies',
    on: settings.enableCompanies,
}) }}

{{ forms.lightswitchField({
    label: 'Quotes'|t('b2b-commerce'),
    instructions: 'Quote requests and the quote workflow.'|t('b2b-commerce'),
    name: 'enableQuotes',
    on: settings.enableQuotes,
}) }}

{{ forms.lightswitchField({
    label: 'Order approvals'|t('b2b-commerce'),
    instructions: 'Reserved for an upcoming release — this setting has no effect yet.'|t('b2b-commerce'),
    name: 'enableApprovals',
    on: settings.enableApprovals,
}) }}

{{ forms.lightswitchField({
    label: 'Pay on account'|t('b2b-commerce'),
    instructions: 'Offer pay on account (on invoice) at checkout for approved companies, within their credit limit. This toggle governs whether the gateway is available; when off, it is never offered regardless of company settings.'|t('b2b-commerce'),
    name: 'enableInvoicing',
    on: settings.enableInvoicing,
}) }}

{{ forms.lightswitchField({
    label: 'Quick order'|t('b2b-commerce'),
    instructions: 'Enable quick order, order lists and reorder for approved buyers. When off, those endpoints return a clean failure and craft.b2b exposes no order-list data.'|t('b2b-commerce'),
    name: 'enableQuickOrder',
    on: settings.enableQuickOrder,
}) }}

{{ forms.lightswitchField({
    label: 'Hide prices for guests'|t('b2b-commerce'),
    instructions: 'Hide prices and disable add-to-cart for visitors without an approved company account.'|t('b2b-commerce'),
    name: 'hidePricesForGuests',
    on: settings.hidePricesForGuests,
}) }}

{{ forms.textField({
    label: 'Admin notification email'|t('b2b-commerce'),
    instructions: 'Receives a notification when a new company registers.'|t('b2b-commerce'),
    name: 'adminNotificationEmail',
    value: settings.adminNotificationEmail,
}) }}

{{ forms.textField({
    label: 'Honeypot field name'|t('b2b-commerce'),
    instructions: 'Name of the hidden anti-spam field on the registration form. Bots that fill it get a success response but nothing is created. Change it if it clashes with a real field, then update your registration template to match.'|t('b2b-commerce'),
    name: 'honeypotFieldName',
    value: settings.honeypotFieldName,
    required: true,
}) }}

<hr>

<h2>{{ 'Company fields'|t('b2b-commerce') }}</h2>

<p class="light">{{ 'Add custom fields to the company edit screen.'|t('b2b-commerce') }}</p>

{{ forms.fieldLayoutDesignerField({
    fieldLayout: companyFieldLayout,
}) }}
