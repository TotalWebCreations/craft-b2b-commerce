{#
    Default B2B quote PDF, shipped inside the plugin. Rendered by Craft Commerce's dompdf-based Pdfs
    service in SITE template mode, resolved through the `b2b-commerce` site template root the plugin
    registers for its own `src/templates` folder (see Plugin::registerSiteTemplateRoot()) — so this
    renders out of the box with no merchant configuration at all.

    To customize, do NOT edit this file: copy
    examples/templates/b2b/pdf/quote.twig into your own templates folder and point the
    "Quote PDF template" plugin setting at your copy. That setting always wins over this default
    when it is set to a non-empty path (see PdfDocuments::quoteTemplatePath()).

    Variables:
      order        — the Commerce Order behind the quote (auto-injected)
      company      — the B2B company element the quote belongs to (may be null)
      validUntil   — the quote validity date (may be null)
      documentType — 'quote'
#}
{% set currency = order.currency %}
<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 12px; color: #222; }
        h1 { font-size: 20px; margin: 0 0 4px; }
        .muted { color: #777; }
        .parties { width: 100%; margin: 16px 0; }
        .parties td { vertical-align: top; width: 50%; }
        table.items { width: 100%; border-collapse: collapse; margin-top: 16px; }
        table.items th, table.items td { border-bottom: 1px solid #ddd; padding: 6px 4px; text-align: left; }
        table.items td.num, table.items th.num { text-align: right; }
        table.totals { width: 40%; margin-left: 60%; margin-top: 12px; }
        table.totals td { padding: 4px; }
        table.totals td.num { text-align: right; }
        .note { margin-top: 20px; font-size: 11px; color: #555; }
    </style>
</head>
<body>
    <h1>{{ 'Quote'|t('b2b-commerce') }}</h1>
    <div class="muted">{{ order.reference ?: order.shortNumber }} &middot; {{ (order.dateOrdered ?? order.dateCreated)|date('short') }}</div>

    <table class="parties">
        <tr>
            <td>
                <strong>{{ 'To'|t('b2b-commerce') }}</strong><br>
                {% if company %}
                    {{ company.title }}<br>
                    {% if company.registrationNumber %}{{ 'Registration number'|t('b2b-commerce') }}: {{ company.registrationNumber }}<br>{% endif %}
                    {% if company.taxId %}{{ 'Tax ID'|t('b2b-commerce') }}: {{ company.taxId }}<br>{% endif %}
                {% endif %}
            </td>
            <td>
                {% if order.b2bPoNumber ?? null %}
                    <strong>{{ 'Purchase order'|t('b2b-commerce') }}:</strong> {{ order.b2bPoNumber }}<br>
                {% endif %}
                {% if validUntil %}
                    <strong>{{ 'Valid until'|t('b2b-commerce') }}:</strong> {{ validUntil|date('short') }}<br>
                {% endif %}
            </td>
        </tr>
    </table>

    <table class="items">
        <thead>
            <tr>
                <th>{{ 'Description'|t('b2b-commerce') }}</th>
                <th class="num">{{ 'Qty'|t('b2b-commerce') }}</th>
                <th class="num">{{ 'Price'|t('b2b-commerce') }}</th>
                <th class="num">{{ 'Total'|t('b2b-commerce') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.lineItems %}
                <tr>
                    <td>{{ item.description }}<br><span class="muted">{{ item.sku }}</span></td>
                    <td class="num">{{ item.qty }}</td>
                    <td class="num">{{ item.salePrice|commerceCurrency(currency) }}</td>
                    <td class="num">{{ item.subtotal|commerceCurrency(currency) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="totals">
        <tr>
            <td>{{ 'Subtotal'|t('b2b-commerce') }}</td>
            <td class="num">{{ order.itemSubtotal|commerceCurrency(currency) }}</td>
        </tr>
        {% for adjustment in order.orderAdjustments %}
            <tr>
                <td>{{ adjustment.name }}</td>
                <td class="num">{{ adjustment.amount|commerceCurrency(currency) }}</td>
            </tr>
        {% endfor %}
        <tr>
            <td><strong>{{ 'Total'|t('b2b-commerce') }}</strong></td>
            <td class="num"><strong>{{ order.totalPrice|commerceCurrency(currency) }}</strong></td>
        </tr>
    </table>

    {% if order.totalTax == 0 and company and company.taxId %}
        <p class="note">{{ 'VAT reverse-charged to the recipient.'|t('b2b-commerce') }}</p>
    {% endif %}

    <p class="note">{{ 'Prices on this quote are fixed for its validity period.'|t('b2b-commerce') }}</p>
</body>
</html>
