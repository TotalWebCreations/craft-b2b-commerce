{% extends 'b2b/_layout' %}

{#
    Company registration form.
    Posts to the `b2b-commerce/registration/register` controller action, which
    creates a pending company plus its admin user. This is a public page, so it
    does not require a login (the shared nav in b2b/_layout stays hidden here).
#}

{% block title %}{{ 'Create a business account'|t('b2b-commerce') }}{% endblock %}

{% block content %}
    <h1>{{ 'Create a business account'|t('b2b-commerce') }}</h1>

    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('b2b-commerce/registration/register') }}
        {# 'b2b/register/thanks' is only an example route — create your own thanks template or change this redirect. #}
        {{ redirectInput('b2b/register/thanks') }}

        <label>{{ 'Company name'|t('b2b-commerce') }} <input type="text" name="companyName" required></label>
        <label>{{ 'Registration number'|t('b2b-commerce') }} <input type="text" name="registrationNumber"></label>
        <label>{{ 'VAT / Tax ID'|t('b2b-commerce') }} <input type="text" name="taxId"></label>
        <label>{{ 'First name'|t('b2b-commerce') }} <input type="text" name="firstName" required></label>
        <label>{{ 'Last name'|t('b2b-commerce') }} <input type="text" name="lastName" required></label>
        <label>{{ 'Email'|t('b2b-commerce') }} <input type="email" name="email" required></label>

        {# Honeypot field: a real visitor never sees or fills this. Bots that fill
           it get a success response but nothing is created. The field name must
           match the `honeypotFieldName` plugin setting (default `b2b_website`). #}
        {% set honeypotFieldName = craft.app.plugins.getPlugin('b2b-commerce').settings.honeypotFieldName %}
        <div style="position:absolute;left:-9999px;" aria-hidden="true">
            <label>{{ 'Leave this field empty'|t('b2b-commerce') }}
                <input type="text" name="{{ honeypotFieldName }}" tabindex="-1" autocomplete="off">
            </label>
        </div>

        <button type="submit">{{ 'Register'|t('b2b-commerce') }}</button>
    </form>
{% endblock %}
