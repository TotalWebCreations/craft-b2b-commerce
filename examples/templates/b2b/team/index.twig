{% extends '_layout' %}

{% block content %}
    <h1>{{ 'Team'|t('b2b-commerce') }}</h1>

    {# craft.b2b.teamMembers returns rows of {user, role} for the current user's company. #}
    <table>
        <thead>
            <tr>
                <th>{{ 'Name'|t('b2b-commerce') }}</th>
                <th>{{ 'Email'|t('b2b-commerce') }}</th>
                <th>{{ 'Role'|t('b2b-commerce') }}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for member in craft.b2b.teamMembers %}
                <tr>
                    <td>{{ member.user.fullName }}</td>
                    <td>{{ member.user.email }}</td>
                    <td>
                        {# Change-role form: one select + save button per member. #}
                        <form method="post" accept-charset="UTF-8">
                            {{ csrfInput() }}
                            {{ actionInput('b2b-commerce/team/change-role') }}
                            {{ hiddenInput('userId', member.user.id) }}
                            <select name="role">
                                <option value="admin"{{ member.role == 'admin' ? ' selected' }}>{{ 'Admin'|t('b2b-commerce') }}</option>
                                <option value="purchaser"{{ member.role == 'purchaser' ? ' selected' }}>{{ 'Purchaser'|t('b2b-commerce') }}</option>
                                <option value="approver"{{ member.role == 'approver' ? ' selected' }}>{{ 'Approver'|t('b2b-commerce') }}</option>
                            </select>
                            <button type="submit">{{ 'Save'|t('b2b-commerce') }}</button>
                        </form>
                    </td>
                    <td>
                        {# Remove form: deletes the membership. #}
                        <form method="post" accept-charset="UTF-8">
                            {{ csrfInput() }}
                            {{ actionInput('b2b-commerce/team/remove') }}
                            {{ hiddenInput('userId', member.user.id) }}
                            <button type="submit">{{ 'Remove'|t('b2b-commerce') }}</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <h2>{{ 'Invite a member'|t('b2b-commerce') }}</h2>

    {# Invite form: posts to the invite action and creates a pending user + membership. #}
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('b2b-commerce/team/invite') }}

        <label>{{ 'First name'|t('b2b-commerce') }} <input type="text" name="firstName" required></label>
        <label>{{ 'Last name'|t('b2b-commerce') }} <input type="text" name="lastName" required></label>
        <label>{{ 'Email'|t('b2b-commerce') }} <input type="email" name="email" required></label>
        <label>{{ 'Role'|t('b2b-commerce') }}
            <select name="role">
                <option value="purchaser">{{ 'Purchaser'|t('b2b-commerce') }}</option>
                <option value="approver">{{ 'Approver'|t('b2b-commerce') }}</option>
                <option value="admin">{{ 'Admin'|t('b2b-commerce') }}</option>
            </select>
        </label>

        <button type="submit">{{ 'Send invitation'|t('b2b-commerce') }}</button>
    </form>
{% endblock %}
