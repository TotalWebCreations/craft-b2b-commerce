{# Partial: show the price or a sign-in prompt, depending on B2B price visibility #}
{% if craft.b2b.canViewPrices %}
    <span class="price">{{ variant.price|commerceCurrency }}</span>
    <form method="post">
        {{ csrfInput() }}
        {{ actionInput('commerce/cart/update-cart') }}
        {{ hiddenInput('purchasableId', variant.id) }}
        <button type="submit">{{ 'Add to cart'|t('b2b-commerce') }}</button>
    </form>
{% else %}
    <a href="{{ url('b2b/register') }}">{{ 'Sign in or register to see prices'|t('b2b-commerce') }}</a>
{% endif %}
