{# Reorder button: posts a completed order's id so the controller copies its still
   available line items into the current cart. Include it in an order row or detail
   view with the order in scope, e.g. {% include 'b2b/orders/_reorder-button' with { order } %}.
   Copy this template into your own site and restyle it to taste. #}
<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('b2b-commerce/quick-order/reorder') }}
    {{ hiddenInput('orderId', order.id) }}

    <button type="submit">{{ 'Reorder'|t('b2b-commerce') }}</button>
</form>
