{# Submit-for-approval form: sends the current cart to the company's approvers when the
   order needs approval (a purchaser over the company approval threshold). Drop it on the
   cart page, e.g. {% include 'b2b/approvals/_submit-button' %}. Submitting an order that
   does not need approval is refused, so show this only when approval is required.
   Copy this template into your own site and restyle it to taste. #}
<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('b2b-commerce/approvals/submit') }}

    <button type="submit">{{ 'Submit for approval'|t('b2b-commerce') }}</button>
</form>
